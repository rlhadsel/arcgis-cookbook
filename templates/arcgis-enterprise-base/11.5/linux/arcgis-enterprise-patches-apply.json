{
    "arcgis": {
        "version": "11.5",
        "run_as_user": "arcgis",
        "repository": {
            "patches": "/opt/software/archives/patches"
        },
        "portal": {
            "install_dir": "/opt",
            "patches": [
                "ArcGIS-115-PFA-*.tar",
                "ArcGIS-115-PFA-*.tar.gz"
            ]
        },
        "server": {
            "install_dir": "/opt",
            "patches": [
                "ArcGIS-115-S-*.tar",
                "ArcGIS-115-S-*.tar.gz"
            ]
        },
        "data_store": {
            "install_dir": "/opt",
            "patches": [
                "ArcGIS-115-DS-*.tar",
                "ArcGIS-115-DS-*.tar.gz"
            ]
        },
        "web_adaptor": {
            "patches": []
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::install_patches]"
    ]
}
