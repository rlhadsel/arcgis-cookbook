{
    "arcgis": {
        "version": "11.5",
        "run_as_user": "arcgis",
        "repository": {
            "patches": "/opt/software/archives/patches"
        },
        "server": {
            "install_dir": "/opt",
            "patches": [
                "ArcGIS-115-S-*.tar",
                "ArcGIS-115-S-*.tar.gz"
            ]
        },
        "geoevent": {
            "patches": [
                "GeoEvent-11.5-*.tar",
                "GeoEvent-11.5-*.tar.gz"
            ]
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::install_patches]",
        "recipe[arcgis-geoevent::install_patches]"
    ]
}
