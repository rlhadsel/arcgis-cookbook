{
    "arcgis": {
        "version": "12.0",
        "run_as_user": "arcgis",
        "run_as_password": "<run_as_password>",
        "fileserver": {
            "directories": [
                "C:\\arcgisvideoserver"
            ],
            "shares": [
                "C:\\arcgisvideoserver"
            ]
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::system]",
        "recipe[arcgis-enterprise::disable_loopback_check]",
        "recipe[arcgis-enterprise::fileserver]"
    ]
}