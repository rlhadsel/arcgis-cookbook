{
    "arcgis": {
        "version": "12.0",
        "run_as_user": "arcgis",
        "run_as_password": "<run_as_password>",
        "configure_windows_firewall": true,
        "repository": {
            "archives": "C:\\Software\\Archives",
            "setups": "C:\\Software\\Setups"
        },
        "video_server": {
            "install_dir": "C:\\Program Files\\ArcGIS\\Video",
            "install_system_requirements": true,
            "authorization_file": "C:\\Software\\AuthorizationFiles\\12.0\\VideoServer.prvc",
            "admin_username": "<video_server_admin_username>",
            "admin_password": "<video_server_admin_password>",
            "directories_root": "\\\\FILESERVER\\arcgisvideoserver",
            "config_store_type": "FILESYSTEM",
            "config_store_connection_string": "\\\\FILESERVER\\arcgisvideoserver\\config-store",
            "log_level": "WARNING",
            "log_dir": "C:\\arcgisvideoserver\\logs",
            "configure_autostart": true,
            "system_properties": {
                "WebContextURL": "https://videoserver.domain.com/video",
                "maxFrameCount": 1000,
                "maxFileUploadSize": 5000,
                "disableServicesDirectory": false
            },
            "ports": "21080,21443,45671"
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::system]",
        "recipe[arcgis-video::server]"
    ]
}