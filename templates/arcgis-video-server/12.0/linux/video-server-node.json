{
    "arcgis": {
        "version": "12.0",
        "run_as_user": "arcgis",
        "repository": {
            "archives": "/opt/software/archives",
            "setups": "/opt/software/setups"
        },
        "video_server": {
            "install_dir": "/opt",
            "install_system_requirements": true,
            "authorization_file": "/opt/software/authorization_files/12.0/video_server.prvc",
            "admin_username": "<video_server_admin_username>",
            "admin_password": "<video_server_admin_password>",
            "primary_server_url": "https://primary:21443/arcgis",
            "log_dir": "/opt/arcgis/video/usr/logs",
            "configure_autostart": true,
            "ports": "21080,21443,45671"
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::system]",
        "recipe[arcgis-video::server_node]"
    ]
}